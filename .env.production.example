# ════════════════════════════════════════════════════════════════════════════
# .env.production.example — Template de configuration pour le déploiement VPS
# ════════════════════════════════════════════════════════════════════════════
#
# 🎯 RÔLE
#   Ce fichier est un TEMPLATE qui documente TOUTES les variables nécessaires
#   pour le déploiement de Météo IA France V1.0 en production sur le VPS OVH.
#
#   Il EST commité sur GitHub (avec des valeurs factices/CHANGEME).
#
# 🔒 USAGE EN PRODUCTION
#   1. Sur le VPS, copier ce fichier vers .env.production :
#      cp .env.production.example .env.production
#
#   2. Éditer .env.production et remplacer TOUTES les valeurs CHANGEME par
#      des valeurs réelles (mots de passe forts générés aléatoirement).
#
#   3. Le fichier .env.production contient les VRAIS secrets. Il est dans
#      .gitignore et NE DOIT JAMAIS être commité.
#
# 🔐 GÉNÉRATION DE MOTS DE PASSE FORTS
#   Sur le VPS, lancer :
#      openssl rand -base64 32
#   pour générer une chaîne cryptographiquement sûre de 44 caractères.
#
# ════════════════════════════════════════════════════════════════════════════


# ────────────────────────────────────────────────────────────────────────────
# 🗄️  POSTGRESQL — Configuration de la base de données
# ────────────────────────────────────────────────────────────────────────────

# Hôte interne au réseau Docker (NE PAS modifier)
DB_HOST=postgres

# Port interne Postgres (NE PAS modifier — c'est le port DANS le container)
DB_PORT=5432

# Nom de la base de données
DB_NAME=meteo_ia_db

# Utilisateur Postgres
DB_USER=meteo_user

# 🚨 MOT DE PASSE FORT À GÉNÉRER SUR LE VPS
# Ne JAMAIS utiliser "CHANGEME" en production !
# Génère avec : openssl rand -base64 32
DB_PASSWORD=CHANGEME_GENERATE_WITH_OPENSSL_RAND_BASE64_32


# ────────────────────────────────────────────────────────────────────────────
# ⚙️  BACKEND EXPRESS — Configuration de l'API Node.js
# ────────────────────────────────────────────────────────────────────────────

# Mode d'exécution Node (production = optimisations activées)
NODE_ENV=production

# Port interne du backend dans le container
PORT=3001

# Origines autorisées pour les requêtes CORS
# Doit inclure le domaine HTTPS de production + éventuellement www
CORS_ORIGINS=https://meteo-ia.fr,https://www.meteo-ia.fr

# Fenêtre de rate-limiting en minutes (par IP, par fenêtre)
RATE_LIMIT_WINDOW_MIN=60

# Nombre maximum de requêtes par fenêtre par IP
RATE_LIMIT_MAX=100

# TTL du cache backend en secondes (10 minutes par défaut)
CACHE_TTL_SECONDS=600


# ────────────────────────────────────────────────────────────────────────────
# 🎨  FRONTEND VITE — Configuration du build React
# ────────────────────────────────────────────────────────────────────────────
#
# 🆕 IMPORTANT : ces variables sont injectées au moment du BUILD via les
#    "args" de docker-compose.yml, PAS au runtime du container.
#
#    Elles n'ont donc PAS besoin d'être dans le .env runtime, mais on les
#    documente ici pour cohérence.

# Active le mode "API réelle" (false = mode mock avec données statiques)
VITE_USE_API=true

# Base URL des appels API depuis le frontend (vide = appels relatifs /api/)
# Le proxy nginx du container frontend route /api/* vers backend:3001
VITE_API_URL=


# ────────────────────────────────────────────────────────────────────────────
# 🌐  DOMAINE & RÉSEAU — Pour mémoire (utilisé hors docker-compose)
# ────────────────────────────────────────────────────────────────────────────
#
# Ces variables ne sont PAS lues par docker-compose mais servent de
# documentation pour les autres scripts (Nginx host, Certbot, etc.)

# Domaine principal de production
DOMAIN=meteo-ia.fr

# Email pour les alertes Certbot (renouvellement HTTPS)
CERTBOT_EMAIL=kadechola@gmail.com


# ────────────────────────────────────────────────────────────────────────────
# 🐍  PIPELINES PYTHON — Configuration des scripts d'acquisition
# ────────────────────────────────────────────────────────────────────────────
#
# Ces variables sont utilisées par les pipelines cron Python sur le VPS.
# Elles tournent EN DEHORS de docker-compose (sur l'OS du VPS directement).

# Clé API Climate Data Store (CDS) pour télécharger ERA5
# Format : "UID:KEY" obtenu sur https://cds.climate.copernicus.eu/api-how-to
# 🚨 GARDER STRICTEMENT SECRÈTE
CDS_API_URL=https://cds.climate.copernicus.eu/api/v2
CDS_API_KEY=CHANGEME_GET_FROM_CDS_CLIMATE_COPERNICUS_EU

# Email/User-Agent pour les requêtes NOMADS (NOAA — bonne pratique)
NOAA_USER_AGENT=meteo-ia-france/1.0 (kadechola@gmail.com)


# ────────────────────────────────────────────────────────────────────────────
# 📝  NOTES POUR LE DÉPLOIEMENT
# ────────────────────────────────────────────────────────────────────────────
#
# Sur le VPS, après avoir copié ce fichier en .env.production :
#
# 1. Générer un DB_PASSWORD fort :
#      openssl rand -base64 32
#
# 2. Récupérer la CDS_API_KEY depuis ton compte CDS :
#      https://cds.climate.copernicus.eu/api-how-to
#
# 3. Vérifier que .env.production est dans .gitignore (déjà le cas)
#
# 4. Lancer le déploiement :
#      docker compose --env-file .env.production up -d --build
#
# 5. Vérifier que tout tourne :
#      docker compose ps
#      curl http://localhost:8080/api/health
#
# 6. Configurer Nginx host pour le reverse proxy HTTPS depuis meteo-ia.fr
#
# 7. Configurer Certbot pour le certificat SSL Let's Encrypt
#
# ════════════════════════════════════════════════════════════════════════════

# Port host backend (3002 si conflit avec autre projet sur 3001)
BACKEND_HOST_PORT=3001
