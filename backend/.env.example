# ═══════════════════════════════════════════════════════════════════════════
# Météo IA France — Backend Express
# Template des variables d'environnement
# ─────────────────────────────────────────────────────────────────────────────
# Pour utiliser ce template :
#   1. cp .env.example .env
#   2. Édite .env avec tes vraies valeurs
#   3. Ne JAMAIS committer .env sur GitHub (il est dans .gitignore)
# ═══════════════════════════════════════════════════════════════════════════


# ─── Serveur Express ─────────────────────────────────────────────────────────
# Port d'écoute du backend
# Local: 3001 (cohérent avec ai-elec-conso)
# VPS prod: 3001 aussi (Nginx fera le reverse proxy depuis port 443)
PORT=3001

# Environnement d'exécution: development | production
# - development : logs verbeux, CORS permissif
# - production  : logs minimes, CORS strict
NODE_ENV=development


# ─── Base de données PostgreSQL ──────────────────────────────────────────────
# Hôte de la DB
# Local Mac : localhost (Docker bridge)
# VPS prod  : localhost aussi (Docker dans le même VPS)
DB_HOST=localhost

# Port de PostgreSQL
# Cohérent avec ton container Docker meteo_ia_pg_db (HANDOFF)
DB_PORT=5433

# Nom de la base
DB_NAME=meteo_ia_db

# Utilisateur PostgreSQL
DB_USER=meteo_user

# Mot de passe PostgreSQL
# ⚠️ NE JAMAIS COMMITER LA VRAIE VALEUR
DB_PASSWORD=your_password_here


# ─── CORS (Cross-Origin Resource Sharing) ────────────────────────────────────
# Liste des origines autorisées à appeler l'API, séparées par des virgules
# Local dev    : http://localhost:5173 (port Vite par défaut)
# VPS prod     : https://meteo-ia-france.fr (à adapter à ton domaine)
# Multi origins: http://localhost:5173,https://meteo-ia-france.fr
CORS_ORIGINS=http://localhost:5173


# ─── Rate limiting ───────────────────────────────────────────────────────────
# Fenêtre de temps en minutes pour compter les requêtes
RATE_LIMIT_WINDOW_MIN=60

# Nombre max de requêtes par IP dans la fenêtre
# HANDOFF: 100 req/h/IP
RATE_LIMIT_MAX=100


# ─── Cache RAM ───────────────────────────────────────────────────────────────
# Durée de vie du cache en secondes
# HANDOFF: cache Express 10 min = 600 secondes
CACHE_TTL_SECONDS=600
